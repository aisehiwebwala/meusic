{
  "version": 2,
  "builds": [
    {
      "src": "BE/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "FE/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/?(.*)",
      "dest": "BE/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "FE/$1"
    }
  ]
}
